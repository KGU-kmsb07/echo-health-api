{
  "project": "Echo Health",
  "model_version": "E.H.ML v.2.0.3",
  "reference_year": "2024",
  "model_policy": "simple-only",
  "disease_model_strategy": {
    "고혈압": "Simple feature Logistic Regression",
    "당뇨": "Simple feature Logistic Regression",
    "심장질환": "Simple feature Logistic Regression",
    "암": "Simple feature Logistic Regression",
    "뇌졸중": "Simple rule fallback",
    "체중관리군": "Rule-based BMI classification"
  },
  "saved_models": {
    "고혈압": {
      "model_name": "Logistic Regression",
      "model_file": "simple/hypertension_logistic_regression.pkl"
    },
    "당뇨": {
      "model_name": "Logistic Regression",
      "model_file": "simple/diabetes_logistic_regression.pkl"
    },
    "심장질환": {
      "model_name": "Logistic Regression",
      "model_file": "simple/heart_disease_logistic_regression.pkl"
    },
    "암": {
      "model_name": "Logistic Regression",
      "model_file": "simple/cancer_logistic_regression.pkl"
    }
  },
  "simple_features": [
    "age",
    "sex",
    "height_cm",
    "weight_kg",
    "waist_cm",
    "bmi",
    "current_smoking",
    "aerobic_activity"
  ],
  "bmi_rule": {
    "formula": "BMI = weight_kg / ((height_cm / 100) ** 2)",
    "weight_management_threshold": 23.0,
    "categories": {
      "BMI < 18.5": "저체중",
      "18.5 <= BMI < 23": "정상",
      "23 <= BMI < 25": "과체중",
      "BMI >= 25": "비만"
    }
  }
}
